# Vite embeds VITE_* at build time. Firebase Console does not store these; use this file locally or GitHub Actions secrets for CI.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
GEMINI_API_KEY=
# Public API base URL (no trailing slash). Required at **build time** for the IDE to call Git, preview, and terminal routes.
# Without it, hosted sooner.sh cannot reach a workspace server — set this to your deployed `server.ts` URL (e.g. Railway).
# Example: https://your-service.up.railway.app
VITE_BACKEND_URL=
# Optional — override OpenRouter-compatible API root (default in app is https://openrouter.ai/api/v1).
#VITE_OPENROUTER_API_BASE=https://openrouter.ai/api/v1
# Legacy alias (same effect as VITE_OPENROUTER_API_BASE if the former is unset):
#VITE_CUSTOM_OPENAI_API_BASE=
# When VITE_BACKEND_URL is set, OpenRouter calls use POST/GET /api/ai/openrouter/* (Firebase session + X-Sooner-OpenRouter-Key).
# Optional — HTTP-Referer sent to OpenRouter from the server (default https://sooner.sh). Match your OpenRouter key referrer allowlist.
#OPENROUTER_HTTP_REFERER=https://sooner.sh
# Optional — extra hostnames allowed for openrouterBase (comma-separated), for self-hosted OpenAI-compatible proxies only.
#OPENROUTER_PROXY_ALLOWED_HOSTS=
# Optional — Vercel AI Gateway proxy target for /api/ai/gateway/* (must remain https://ai-gateway.vercel.sh/...).
#AI_GATEWAY_PROXY_ORIGIN=https://ai-gateway.vercel.sh/v1
# Optional — signed preview links: min 16 chars. When set, GET /preview/:id requires ?pt= or spv cookie from issued URL.
#PREVIEW_URL_SECRET=
# Optional — absolute origin for GET /api/projects/:id/preview-url when reverse proxies hide the public host (no trailing slash).
#PUBLIC_PREVIEW_ORIGIN=https://your-workspace.up.railway.app
#PREVIEW_URL_TTL_SEC=3600
# Optional — comma-separated extra browser origins allowed by CORS (e.g. https://sooner.sh,https://preview.sooner.sh). sooner.sh and Railway public domain are allowed by default when set.
#CORS_ORIGINS=
# Optional: full path to `flutter` on the workspace server (Flutter live preview / static web build).
#FLUTTER_BIN=/path/to/flutter/bin/flutter
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_STORAGE_BUCKET=
# CMS admin credentials
CMS_ADMIN_USER=
CMS_ADMIN_PASS=
CMS_JWT_SECRET=
# Google Indexing API: enable "Web Search Indexing API" in Google Cloud Console
# and grant the service account's email the "Owner" role in Google Search Console.
# No extra env var needed — uses the same FIREBASE_SERVICE_ACCOUNT credentials.
#
# Square (optional) — billing demo: open /billing/square in the app; secrets only on the Node server below.
# All four are required for /api/square/config. Use Sandbox token from Square Developer Dashboard → Credentials.
#SQUARE_APPLICATION_ID=
#SQUARE_LOCATION_ID=
#SQUARE_ACCESS_TOKEN=
#SQUARE_PLAN_VARIATION_ID=   # Optional default: Catalog → Subscriptions → plan variation id (billing page lists catalog; this preselects / fallback)
#SQUARE_ENVIRONMENT=sandbox  # omit or sandbox = sandbox APIs; production = production Connect + Web SDK

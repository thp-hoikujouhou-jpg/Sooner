{
  "name": "sooner",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "node --import tsx server.ts",
    "build": "vite build",
    "postbuild": "node scripts/seo-postbuild.mjs",
    "build:ci": "node scripts/check-vite-env.mjs && vite build && node scripts/seo-postbuild.mjs",
    "preview": "vite preview",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "lint": "tsc --noEmit",
    "deploy:legacy-auth-redirects": "firebase deploy --only hosting --config legacy-hosting/firebase.json"
  },

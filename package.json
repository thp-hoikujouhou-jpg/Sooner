    "express": "^4.21.2",
    "file-saver": "^2.0.5",
    "firebase": "^12.12.0",
    "firebase-admin": "^13.8.0",
    "html2canvas": "^1.4.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.8.0",
    "monaco-editor": "^0.55.1",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
